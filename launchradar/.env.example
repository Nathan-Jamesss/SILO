# ── Application ──────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./launchradar.db

# ── Scraping ──────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
DEFAULT_KEYWORD=startup
DEFAULT_REGION=

# ── API Keys ──────────────────────────────────────────
# Google AI Studio (free): https://aistudio.google.com/
GEMINI_API_KEY=your_key_here

# Eventbrite (free): https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=your_key_here

# ── Alerts (optional) ─────────────────────────────────
# Leave empty to disable webhook alerts
ALERT_WEBHOOK_URL=
